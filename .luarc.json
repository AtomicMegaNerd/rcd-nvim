{
  "$schema": "https://raw.githubusercontent.com/sumneko/vscode-lua/master/setting/schema.json",
  "runtime": {
    "version": "LuaJIT"
  },
  "workspace": {
    "checkThirdParty": false,
    "library": [
      "$VIMRUNTIME/lua",
      "${3rd}/luv/library",
      "$XDG_DATA_HOME/nvim/lazy/blink.cmp/lua",
      "$XDG_DATA_HOME/nvim/lazy/catppuccin/lua",
      "$XDG_DATA_HOME/nvim/lazy/conform.nvim/lua",
      "$XDG_DATA_HOME/nvim/lazy/diffview.nvim/lua",
      "$XDG_DATA_HOME/nvim/lazy/lazy.nvim/lua",
      "$XDG_DATA_HOME/nvim/lazy/mini.nvim/lua",
      "$XDG_DATA_HOME/nvim/lazy/neogit/lua",
      "$XDG_DATA_HOME/nvim/lazy/nvim-coverage/lua",
      "$XDG_DATA_HOME/nvim/lazy/nvim-lint/lua",
      "$XDG_DATA_HOME/nvim/lazy/nvim-lspconfig/lua",
      "$XDG_DATA_HOME/nvim/lazy/nvim-treesitter/lua",
      "$XDG_DATA_HOME/nvim/lazy/oil.nvim/lua",
      "$XDG_DATA_HOME/nvim/lazy/plenary.nvim/lua",
      "$XDG_DATA_HOME/nvim/lazy/snacks.nvim/lua",
      "$XDG_DATA_HOME/nvim/lazy/todo-comments.nvim/lua"
    ]
  }
}
